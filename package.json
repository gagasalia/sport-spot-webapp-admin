{
  "name": "sportify-admin",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "concurrently \"npm:build:css:watch\" \"npm:serve\"",
    "serve": "ng serve",
    "dev": "npm run build:css:watch & npm start",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "build:css": "tailwindcss -i ./src/input.css -o ./src/output.css",
    "build:css:watch": "tailwindcss -i ./src/input.css -o ./src/output.css --watch"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.3.0",
    "@angular/cdk": "^20.2.14",
    "@angular/common": "^20.3.0",
    "@angular/compiler": "^20.3.0",
    "@angular/core": "^20.3.0",
    "@angular/forms": "^20.3.0",
    "@angular/platform-browser": "^20.3.0",
    "@angular/platform-server": "^20.3.0",
    "@angular/router": "^20.3.0",
    "@angular/ssr": "^20.3.0",
    "@maskito/angular": "^3.11.1",
    "@maskito/core": "^3.11.1",
    "@maskito/kit": "^3.11.1",
    "@maskito/phone": "^3.11.1",
    "@ng-web-apis/common": "^4.12.2",
    "@ng-web-apis/intersection-observer": "^4.12.2",
    "@ng-web-apis/mutation-observer": "^4.12.2",
    "@ng-web-apis/platform": "^4.12.2",
    "@ng-web-apis/resize-observer": "^4.12.2",
    "@ng-web-apis/screen-orientation": "^4.12.2",
    "@taiga-ui/addon-mobile": "^4.64.0",
    "@taiga-ui/cdk": "^4.64.0",
    "@taiga-ui/core": "^4.64.0",
    "@taiga-ui/event-plugins": "^4.0.2",
    "@taiga-ui/experimental": "^4.64.0",
    "@taiga-ui/i18n": "^4.64.0",
    "@taiga-ui/icons": "^4.64.0",
    "@taiga-ui/kit": "^4.64.0",
    "@taiga-ui/layout": "^4.64.0",
    "@taiga-ui/polymorpheus": "^4.9.0",
    "@tailwindcss/cli": "^4.1.15",
    "express": "^5.1.0",
    "libphonenumber-js": "^1.12.31",
    "rxjs": "~7.8.0",
    "tailwindcss": "^4.1.15",
    "tslib": "^2.3.0",
    "uuid": "^13.0.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^20.3.5",
    "@angular/cli": "^20.3.5",
    "@angular/compiler-cli": "^20.3.0",
    "@types/express": "^5.0.1",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^20.17.19",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.2.1",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "less": "^4.4.2",
    "typescript": "~5.9.2"
  }
}
